# Copy to comfy_proxy.env (untracked) and set your real values.
# Both comfy_proxy.sh and comfy_proxy.py load comfy_proxy.env automatically;
# a pre-set environment variable still overrides these. Override the path with
# COMFY_PROXY_ENV=/path/to/file.

# ComfyUI server the proxy forwards to.
COMFY_URL=http://127.0.0.1:8188

# Address the editor is served on. 0.0.0.0 = reachable from the LAN.
PROXY_HOST=0.0.0.0

# Port the editor is served on.
PROXY_PORT=8189
